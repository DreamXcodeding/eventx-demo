# EventX API — ทุกค่ามี default แล้ว (รัน bun dev ได้เลยโดยไม่ต้องมี .env)
# คัดลอกเป็น .env เฉพาะเมื่ออยากเปลี่ยนค่า (อย่า commit .env)

# ไฟล์ SQLite (default: eventx.db ในโฟลเดอร์ apps/api)
DATABASE_FILE=eventx.db
# secret เซ็น JWT — ตั้งค่าจริงก่อน production (default dev มีให้แล้ว)
JWT_SECRET=change-me-to-a-long-random-string-min-16
# พอร์ต API
PORT=3000
# origin frontend ที่อนุญาต CORS (คั่นด้วย comma)
CORS_ORIGIN=http://localhost:5173,https://dreamxcodeding.github.io
